# SentinelIQ — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Data Paths ─────────────────────────────────────────────────────────────
# Absolute path to the directory containing NASA CMAPSS .txt files
SENTINELIQ_DATA_DIR=./data/raw
SENTINELIQ_PROCESSED_DIR=./data/processed
SENTINELIQ_MODEL_DIR=./models
SENTINELIQ_OUTPUT_DIR=./outputs

# ─── Model Configuration ────────────────────────────────────────────────────
SENTINELIQ_RANDOM_SEED=42
# Dataset to train on: FD001 | FD002 | FD003 | FD004 | ALL
SENTINELIQ_DATASET=FD001

# ─── Phase 16: Database (PostgreSQL / Supabase) ──────────────────────────────
# asyncpg-format URL — used by SQLAlchemy async engine
# Local dev (Docker):
DATABASE_URL=postgresql+asyncpg://sentineliq:sentineliq@localhost:5432/sentineliq
# Supabase (production):
# DATABASE_URL=postgresql+asyncpg://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Plain postgres:// is also accepted — the engine auto-converts to asyncpg driver

# ─── Supabase (optional — for Supabase JS client / dashboard) ────────────────
# SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← keep secret, backend only

# ─── Phase 15: FastAPI Server ────────────────────────────────────────────────
ML_SERVER_HOST=0.0.0.0
ML_SERVER_PORT=8000
# ML_SERVER_URL=http://localhost:8000  ← used by frontend / Next.js

# ─── Phase 18+: Frontend / Auth ──────────────────────────────────────────────
# CLERK_SECRET_KEY=sk_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...

