# SentinelIQ — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Data Paths ─────────────────────────────────────────────────────────────
# Absolute path to the directory containing NASA CMAPSS .txt files
# (train_FD001.txt, test_FD001.txt, RUL_FD001.txt, etc.)
SENTINELIQ_DATA_DIR=./data/raw

# Directory for preprocessed/cached data
SENTINELIQ_PROCESSED_DIR=./data/processed

# Directory for saved model weights
SENTINELIQ_MODEL_DIR=./models

# Directory for outputs (plots, logs, reports)
SENTINELIQ_OUTPUT_DIR=./outputs

# ─── Model Configuration ────────────────────────────────────────────────────
# Random seed for reproducibility
SENTINELIQ_RANDOM_SEED=42

# Dataset to train on: FD001 | FD002 | FD003 | FD004 | ALL
SENTINELIQ_DATASET=FD001

# ─── Future: Backend API (Phase 15+) ────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:port/dbname
# ML_SERVER_URL=http://localhost:8000
# CLERK_SECRET_KEY=sk_...
