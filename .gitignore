# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual Environments ───────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data — never commit raw/processed datasets ─────────────────────────────
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/README.md

# ── Models — use DVC or Git LFS instead ───────────────────────────────────
models/*.pkl
models/*.pt
models/*.pth
models/*.h5
models/*.joblib
!models/.gitkeep

# ── Secrets & Credentials ─────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials.json
service_account.json
client_secret.json

# ── OS & IDE ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Logs & Outputs ────────────────────────────────────────────────────────
logs/
*.log
mlruns/
wandb/
outputs/
reports/figures/*.png
reports/figures/*.pdf
reports/figures/*.svg

# ── DVC ───────────────────────────────────────────────────────────────────
.dvc/tmp
.dvc/cache

# ── Next.js & Frontend Node ───────────────────────────────────────────────
node_modules/
.next/
out/
.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Databases & Runtime State ─────────────────────────────────────────────
db/*.db
db/*.sqlite
*.sqlite3
postgres-data/
pgdata/

# ── Docker ────────────────────────────────────────────────────────────────
docker-volumes/

# ── Test & Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Keep directory structure (explicit allowlist) ─────────────────────────
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!models/.gitkeep
!outputs/.gitkeep
!reports/figures/.gitkeep
